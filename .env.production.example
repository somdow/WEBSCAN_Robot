# ============================================================================
# HELLO WEB_SCANS — Production Environment Configuration
# ============================================================================
# Copy this file to .env on your production server and fill in all values.
# NEVER commit the .env file to version control.
# ============================================================================

APP_NAME="HELLO WEB_SCANS"
APP_ENV=production
APP_KEY=                              # Run: php artisan key:generate
APP_DEBUG=false                       # MUST be false in production
APP_URL=https://yourdomain.com        # Your production domain with HTTPS

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                     # Use "warning" or "error" in production

# ── Database (MySQL recommended for production) ──────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hello_seo
DB_USERNAME=                          # Your MySQL username
DB_PASSWORD=                          # Your MySQL password

# ── Session ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true                  # Encrypt session data in production
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true            # HTTPS-only cookies

# ── Queue & Cache ────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database             # Use "redis" if available for better performance
CACHE_STORE=database                  # Use "redis" if available

# ── Redis (optional, recommended for queue/cache) ────────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Mail (SMTP for production) ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailgun.org            # Your SMTP host (Mailgun, SES, Postmark, etc.)
MAIL_PORT=587
MAIL_USERNAME=                        # SMTP username
MAIL_PASSWORD=                        # SMTP password
MAIL_FROM_ADDRESS="hello@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── AI Providers ─────────────────────────────────────────────────────────────
# Users configure their own API keys in profile settings.
# These are fallback/default keys (optional).
AI_DEFAULT_PROVIDER=gemini
AI_GEMINI_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash
AI_OPENAI_KEY=
AI_OPENAI_MODEL=gpt-4o
AI_ANTHROPIC_KEY=
AI_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_KEY=pk_live_...                # Publishable key (starts with pk_live_)
STRIPE_SECRET=sk_live_...             # Secret key (starts with sk_live_)
STRIPE_WEBHOOK_SECRET=whsec_...       # Webhook signing secret
CASHIER_CURRENCY=usd
CASHIER_CURRENCY_LOCALE=en

# ── Stripe Plan Price IDs (from Stripe Dashboard → Products) ────────────────
# Free plan typically has no Stripe prices (leave empty)
STRIPE_FREE_MONTHLY_PRICE_ID=
STRIPE_FREE_ANNUAL_PRICE_ID=
# Pro plan
STRIPE_PRO_MONTHLY_PRICE_ID=price_...   # Monthly price ID for Pro plan
STRIPE_PRO_ANNUAL_PRICE_ID=price_...    # Annual price ID for Pro plan
# Agency plan
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_... # Monthly price ID for Agency plan
STRIPE_AGENCY_ANNUAL_PRICE_ID=price_...  # Annual price ID for Agency plan

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
